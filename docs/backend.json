
{
  "entities": {
    "ContactFormSubmission": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ContactFormSubmission",
      "type": "object",
      "description": "Represents a contact form submission from the website.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "company": { "type": "string" },
        "message": { "type": "string" },
        "submissionDate": { "type": "string", "format": "date-time" },
        "status": {
          "type": "string",
          "enum": ["New", "Contacted", "Follow up", "Closed"]
        }
      },
      "required": ["id", "name", "email", "message", "submissionDate"]
    },
    "CallRequest": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "CallRequest",
      "type": "object",
      "description": "Represents a request for a call back from a potential client.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "submissionDate": { "type": "string", "format": "date-time" },
        "status": {
          "type": "string",
          "enum": ["New", "Contacted", "Follow up", "Closed"]
        }
      },
      "required": ["id", "name", "email", "phone", "submissionDate"]
    },
    "Note": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Note",
      "type": "object",
      "description": "Represents a note added to a submission or request.",
      "properties": {
        "id": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string", "description": "Base64 or URL for screenshots" },
        "createdBy": { "type": "string", "format": "email" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "content", "createdBy", "createdAt"]
    },
    "Task": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Task",
      "type": "object",
      "description": "Represents a task in the admin dashboard.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "summary": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "dueDate": { "type": "string", "format": "date" },
        "status": {
          "type": "string",
          "enum": ["New", "In Progress", "Completed"]
        },
        "assignedTo": {
          "type": "array",
          "items": { "type": "string", "format": "email" }
        }
      },
      "required": ["id", "title", "createdAt"]
    },
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user profile in the system.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" }
      },
      "required": ["id", "name", "email"]
    },
    "Project": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Project",
      "type": "object",
      "description": "Represents a customer project.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["New", "In Progress", "Hold", "Cancelled", "Completed"] },
        "projectType": { "type": "string", "enum": ["Fixed", "Monthly"] },
        "clientId": { "type": "string" },
        "budget": { "type": "number" },
        "workHours": { "type": "number" },
        "startDate": { "type": "string", "format": "date" },
        "handoverDate": { "type": "string", "format": "date" },
        "managerEmail": { "type": "string" },
        "assignedEmails": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "status", "createdAt"]
    },
    "Client": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Client",
      "type": "object",
      "description": "Represents a business client.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "company": { "type": "string" },
        "reference": { "type": "string" },
        "country": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "createdAt"]
    },
    "FinanceRecord": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "FinanceRecord",
      "type": "object",
      "description": "Represents a financial transaction or invoice.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string", "description": "The main heading or title of the transaction" },
        "referenceNote": { "type": "string", "description": "Detailed reference notes and attachments description" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["Income", "Expense"] },
        "status": { "type": "string", "enum": ["Paid", "Unpaid", "Cancelled"] },
        "date": { "type": "string", "format": "date" },
        "projectId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdBy": { "type": "string" },
        "isDeleted": { "type": "boolean", "default": false }
      },
      "required": ["id", "title", "amount", "type", "status", "date"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      { "path": "/contact_form_submissions/{submissionId}", "definition": { "entityName": "ContactFormSubmission" } },
      { "path": "/call_requests/{requestId}", "definition": { "entityName": "CallRequest" } },
      { "path": "/tasks/{taskId}", "definition": { "entityName": "Task" } },
      { "path": "/tasks/{taskId}/notes/{noteId}", "definition": { "entityName": "Note" } },
      { "path": "/internal_tasks/{taskId}", "definition": { "entityName": "Task" } },
      { "path": "/internal_tasks/{taskId}/notes/{noteId}", "definition": { "entityName": "Note" } },
      { "path": "/users/{userId}", "definition": { "entityName": "UserProfile" } },
      { "path": "/projects/{projectId}", "definition": { "entityName": "Project" } },
      { "path": "/projects/{projectId}/notes/{noteId}", "definition": { "entityName": "Note" } },
      { "path": "/projects/{projectId}/tasks/{taskId}", "definition": { "entityName": "Task" } },
      { "path": "/projects/{projectId}/tasks/{taskId}/notes/{noteId}", "definition": { "entityName": "Note" } },
      { "path": "/clients/{clientId}", "definition": { "entityName": "Client" } },
      { "path": "/finance/{recordId}", "definition": { "entityName": "FinanceRecord" } }
    ]
  }
}
